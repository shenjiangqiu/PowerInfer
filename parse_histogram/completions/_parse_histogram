_parse_histogram__subcmd__print_commands() {
    local commands; commands=()
    _describe -t commands 'parse_histogram print commands' commands "$@"
}
(( $+functions[_parse_histogram__subcmd__simulate_commands] )) ||
_parse_histogram__subcmd__simulate_commands() {
    local commands; commands=()
    _describe -t commands 'parse_histogram simulate commands' commands "$@"
}
(( $+functions[_parse_histogram__subcmd__sparsity_commands] )) ||
_parse_histogram__subcmd__sparsity_commands() {
    local commands; commands=()
    _describe -t commands 'parse_histogram sparsity commands' commands "$@"
}
(( $+functions[_parse_histogram__subcmd__to-cycle_commands] )) ||
_parse_histogram__subcmd__to-cycle_commands() {
    local commands; commands=()
    _describe -t commands 'parse_histogram to-cycle commands' commands "$@"

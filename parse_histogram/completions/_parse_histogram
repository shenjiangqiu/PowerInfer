}
(( $+functions[_parse_histogram__subcmd__help__subcmd__simulate_commands] )) ||
_parse_histogram__subcmd__help__subcmd__simulate_commands() {
    local commands; commands=()
    _describe -t commands 'parse_histogram help simulate commands' commands "$@"
}
(( $+functions[_parse_histogram__subcmd__help__subcmd__sparsity_commands] )) ||
_parse_histogram__subcmd__help__subcmd__sparsity_commands() {
    local commands; commands=()
    _describe -t commands 'parse_histogram help sparsity commands' commands "$@"

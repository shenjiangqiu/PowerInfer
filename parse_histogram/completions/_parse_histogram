#compdef parse_histogram

autoload -U is-at-least

_parse_histogram() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-f+[Path to the binary file]:FILE:_files' \
'--file=[Path to the binary file]:FILE:_files' \
'-l+[Filter by layer (only process records with this layer id)]:LAYER:_default' \
'--layer=[Filter by layer (only process records with this layer id)]:LAYER:_default' \
'-b+[Filter by batch (only process records with this batch id)]:BATCH:_default' \
'--batch=[Filter by batch (only process records with this batch id)]:BATCH:_default' \
'-h[Print help]' \
'--help[Print help]' \
":: :_parse_histogram_commands" \
"*::: :->parse_histogram" \
&& ret=0
    case $state in
    (parse_histogram)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:parse_histogram-command-$line[1]:"
        case $line[1] in
            (histogram)
_arguments "${_arguments_options[@]}" : \
'-o+[Save histogram as JSON to this file]:OUTPUT:_files' \
'--output=[Save histogram as JSON to this file]:OUTPUT:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(print)
_arguments "${_arguments_options[@]}" : \
'-n+[Number of records to print]:COUNT:_default' \
'--count=[Number of records to print]:COUNT:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(sparsity)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(simulate)
_arguments "${_arguments_options[@]}" : \
'-t+[Activation threshold (default\: 0.0)]:THRESHOLD:_default' \
'--threshold=[Activation threshold (default\: 0.0)]:THRESHOLD:_default' \
'-o+[Save result as JSON to this file (auto-derived if omitted)]:OUTPUT:_files' \
'--output=[Save result as JSON to this file (auto-derived if omitted)]:OUTPUT:_files' \
'-r+[Path to remap JSON for balanced bank placement]:REMAP:_files' \
'--remap=[Path to remap JSON for balanced bank placement]:REMAP:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(to-cycle)
_arguments "${_arguments_options[@]}" : \
'-t+[Activation threshold for simulation (default\: 0.0)]:THRESHOLD:_default' \
'--threshold=[Activation threshold for simulation (default\: 0.0)]:THRESHOLD:_default' \
'-o+[Save cycle result as JSON (default\: stdout)]:OUTPUT:_files' \
'--output=[Save cycle result as JSON (default\: stdout)]:OUTPUT:_files' \
'-r+[Path to remap JSON for balanced bank placement]:REMAP:_files' \
'--remap=[Path to remap JSON for balanced bank placement]:REMAP:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(parse-json)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_parse_histogram__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:parse_histogram-help-command-$line[1]:"
        case $line[1] in
            (histogram)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(print)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sparsity)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(simulate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(to-cycle)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(parse-json)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_parse_histogram_commands] )) ||
_parse_histogram_commands() {
    local commands; commands=(
'histogram:Compute per-layer histograms of positive-score positions' \
'print:Print info of the first N records' \
'sparsity:Compute sparsity statistics (overall and per-layer)' \
'simulate:Run PIM simulation with given activation threshold' \
'to-cycle:Convert simulation stats to cycle counts (auto-runs simulation if needed)' \
'parse-json:' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'parse_histogram commands' commands "$@"
}
